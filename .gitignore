# ──────────────────────────────────────────────────────────────────────────────
# Digital Clone — .gitignore
# Golden rule: NEVER commit secrets or runtime state. Only commit code & templates.
# ──────────────────────────────────────────────────────────────────────────────

# Secrets & environment ────────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.key
*.pem
*.crt
*.p12
secrets/

# Persistent service volumes (runtime state, DB data, model weights) ────────────
data/
n8n_data/
ollama_data/
postgres_data/
open_webui_data/
*.sqlite
*.db

# n8n exported credentials (encrypted blobs still leak metadata — keep them out) ─
n8n/credentials/*.json
!n8n/credentials/.gitkeep
!n8n/credentials/README.md

# Logs & temp ───────────────────────────────────────────────────────────────────
*.log
logs/
tmp/
.cache/

# Backups (generated by scripts/backup.sh) ──────────────────────────────────────
backups/
*.dump
*.tar.gz

# OS / editor cruft ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*~
