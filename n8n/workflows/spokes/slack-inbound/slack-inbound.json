        "text": "={{ '⚠️ ' + ($json.ai_guardrail_message || 'This action is not permitted.') }}",
        "otherOptions": {
          "mrkdwn": true
        }
      },
      "id": "b2c3d4e5-2000-4000-b000-000000000008",
      "name": "Post Denial (deny)",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 2,
