# ══════════════════════════════════════════════════════════════════════════════
#  DIGITAL CLONE — Central Configuration
# ──────────────────────────────────────────────────────────────────────────────
#  1. Copy this file:           cp .env.example .env
#  2. Generate strong secrets:  see commands noted beside each REQUIRED value.
#  3. NEVER commit your real .env — it is git-ignored by default.
#
#  Every value the stack needs lives here. docker-compose.yml reads ONLY from
#  this file. If a service needs a new value, add it here — never hardcode.
# ══════════════════════════════════════════════════════════════════════════════


# ┌────────────────────────────────────────────────────────────────────────────┐
# │ 0. GLOBAL                                                                    │
# └────────────────────────────────────────────────────────────────────────────┘
# Logical project name — prefixes container names & the docker network.
COMPOSE_PROJECT_NAME=digital-clone
# Host timezone — used by n8n cron triggers so "18:00 daily" means YOUR 18:00.
GENERIC_TIMEZONE=Asia/Kolkata
TZ=Asia/Kolkata


# ┌────────────────────────────────────────────────────────────────────────────┐
# │ 1. SERVICE TOGGLES  (the "modularity" switches)                             │
# │    Set to "false" to skip pulling/handling an optional service in scripts.  │
# │    To fully remove a service from the runtime, also comment it out in       │
# │    docker-compose.yml (each optional block is clearly marked).              │
# └────────────────────────────────────────────────────────────────────────────┘
ENABLE_OPEN_WEBUI=true          # Web playground for Ollama. Safe to disable in prod.
ENABLE_GPU=false                # true => uncomment the GPU block in docker-compose.yml.


# ┌────────────────────────────────────────────────────────────────────────────┐
# │ 2. PORTS  (host-side). Change if a port is already taken on your machine.   │
# └────────────────────────────────────────────────────────────────────────────┘
N8N_PORT=5678
OLLAMA_PORT=11434
OPEN_WEBUI_PORT=8080
POSTGRES_PORT=5432              # Exposed for local DB tooling; remove mapping in prod.


# ┌────────────────────────────────────────────────────────────────────────────┐
# │ 3. POSTGRES  (state store for n8n + your custom activity_logs)              │
# │    REQUIRED password:  openssl rand -base64 24                              │
# └────────────────────────────────────────────────────────────────────────────┘
POSTGRES_USER=digital_clone
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=digital_clone


# ┌────────────────────────────────────────────────────────────────────────────┐
# │ 4. N8N  (orchestration engine)                                             │
# └────────────────────────────────────────────────────────────────────────────┘
# Encryption key for stored credentials. REQUIRED & IMMUTABLE once set.
# Generate:  openssl rand -hex 32
# If you lose/change this, ALL saved n8n credentials become unreadable.
N8N_ENCRYPTION_KEY=CHANGE_ME_run_openssl_rand_hex_32

# Public-facing host/URL. For local dev, localhost is fine.
# Behind a reverse proxy with HTTPS, set these to your real domain.
N8N_HOST=localhost
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/

# Secure cookies REQUIRE HTTPS. Keep false for plain-http localhost; set true in prod.
N8N_SECURE_COOKIE=false

# Basic-auth gate on the n8n UI. Strongly recommended even locally.
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME_strong_ui_password


# ┌────────────────────────────────────────────────────────────────────────────┐
# │ 5. OLLAMA  (local inference engine — "the brain")                          │
# │    Internal URL for service-to-service calls is http://ollama:11434        │
# │    (use that inside n8n nodes, NOT localhost).                             │
# └────────────────────────────────────────────────────────────────────────────┘
# Comma-separated models auto-pulled by scripts/pull-models.sh on first boot.
OLLAMA_MODELS=llama3:8b,deepseek-r1:8b
# Default model the AI "Hub" routes through (see docs/04-workflow-design.md).
OLLAMA_ROUTER_MODEL=llama3:8b
# Model used for heavy analytical/financial reasoning (cron debrief).
OLLAMA_ANALYST_MODEL=deepseek-r1:8b
# How long Ollama keeps a model resident in RAM/VRAM between calls.
OLLAMA_KEEP_ALIVE=15m


# ┌────────────────────────────────────────────────────────────────────────────┐
# │ 6. INTEGRATION SECRETS  ("Spokes")                                          │
# │    These are OPTIONAL. Only fill in the spokes YOU use.                     │
# │    Forking for Discord instead of Slack? Ignore the Slack block, fill the   │
# │    Discord one, and wire your spoke per docs/05-adding-a-spoke.md.          │
# └────────────────────────────────────────────────────────────────────────────┘

# --- Slack spoke (default inbound) -------------------------------------------
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_DEBRIEF_CHANNEL=#executive-debriefs

# --- Discord spoke (alt inbound — example fork target) -----------------------
DISCORD_BOT_TOKEN=
DISCORD_DEBRIEF_CHANNEL_ID=

# --- Brokerage / trading spoke (READ-ONLY keys only) -------------------------
# The AI core is forbidden from trading (see system prompt guardrails).
# Provision keys with read-only scope at the broker. Alpaca shown as example.
BROKER_API_BASE_URL=https://paper-api.alpaca.markets
BROKER_API_KEY_ID=
BROKER_API_SECRET_KEY=
