# ══════════════════════════════════════════════════════════════════════════════
#  DIGITAL CLONE — Central Configuration
# ══════════════════════════════════════════════════════════════════════════════
#
#  Quickstart (2 minutes):
#    1. cp .env.example .env
#    2. Fill in REQUIRED values marked with ██ (sections 1-3 only)
#    3. docker compose up -d
#    4. Add spoke creds one-by-one as needed (section 6)
#
#  Generate secrets on your machine:
#    DB password  : openssl rand -base64 24
#    N8N encrypt  : openssl rand -hex 32
#    UI password  : openssl rand -base64 18
#
#  NEVER commit .env — it is git-ignored. Treat it like a root password.
# ══════════════════════════════════════════════════════════════════════════════


# ╔════════════════════════════════════════════════════════════════════════════╗
# ║  1. REQUIRED — Core Stack                                                  ║
# ║     Without these, nothing starts.                                         ║
# ╚════════════════════════════════════════════════════════════════════════════╝

# --- Project identity ---
COMPOSE_PROJECT_NAME=digital-clone

# --- Timezone (all cron/schedule nodes use this) ---
GENERIC_TIMEZONE=Asia/Kolkata
TZ=Asia/Kolkata

# --- Ports (change if anything conflicts) ---
N8N_PORT=5678
OLLAMA_PORT=11434
POSTGRES_PORT=5432

# --- PostgreSQL (state store) ---
POSTGRES_USER=digital_clone
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password                  # ██ REQUIRED: openssl rand -base64 24
POSTGRES_DB=digital_clone

# --- n8n (orchestration engine) ---
N8N_ENCRYPTION_KEY=CHANGE_ME_run_openssl_rand_hex_32            # ██ REQUIRED: openssl rand -hex 32
N8N_HOST=localhost
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/
N8N_SECURE_COOKIE=false
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME_strong_ui_password            # ██ REQUIRED: change this

# --- Ollama (local LLM — "the brain") ---
# Internal URL = http://ollama:11434 (use inside n8n nodes, never localhost)
OLLAMA_MODELS=llama3:8b,deepseek-r1:8b
OLLAMA_ROUTER_MODEL=llama3:8b                                   # Fast model for routing/replies
OLLAMA_ANALYST_MODEL=deepseek-r1:8b                             # Heavy model for data analysis
OLLAMA_KEEP_ALIVE=15m


# ╔════════════════════════════════════════════════════════════════════════════╗
# ║  2. OPTIONAL — Modules & Services                                          ║
# ╚════════════════════════════════════════════════════════════════════════════╝

# --- Open WebUI (chat playground for Ollama) ---
ENABLE_OPEN_WEBUI=true
OPEN_WEBUI_PORT=8080

# --- OpenClaw (multi-provider AI assistant: WhatsApp/Telegram/Discord/etc) ---
ENABLE_OPENCLAW=true                                             # Set false if only using n8n spokes
OPENCLAW_MODEL=ollama/llama3:8b
OPENCLAW_GATEWAY_PORT=18789

# --- GPU acceleration ---
ENABLE_GPU=false                                                 # true → uncomment GPU block in docker-compose.yml


# ╔════════════════════════════════════════════════════════════════════════════╗
# ║  3. INTEGRATION SPOKES                                                     ║
# ║     Fill ONLY the ones you use. Each spoke has a README with setup steps.  ║
# ║     All keys are OPTIONAL — empty = spoke inactive.                        ║
# ╚════════════════════════════════════════════════════════════════════════════╝
#
#   Quick reference:
#     Slack    → api.slack.com/apps          |  Telegram → t.me/BotFather
#     WhatsApp → console.twilio.com          |  Discord  → discord.com/developers
#     Gmail    → console.cloud.google.com    |  Kite     → kite.trade
#     Broker   → your broker's developer portal

# ── Slack ───────────────────────────────────────────────────────────────────
# Create app at api.slack.com/apps → OAuth & Permissions → Bot Token
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_DEBRIEF_CHANNEL=#executive-debriefs

# ── Telegram ─────────────────────────────────────────────────────────────────
# Chat @BotFather → /newbot → copy the token
# Then add token in n8n → Credentials → Telegram API
TELEGRAM_BOT_TOKEN=

# ── WhatsApp (via Twilio) ────────────────────────────────────────────────────
# console.twilio.com → Account SID + Auth Token + WhatsApp sandbox number
# Add these to n8n → Credentials → Twilio API (name: "Digital Clone Twilio")
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+14155238886                              # Your Twilio WhatsApp number

# ── Discord ──────────────────────────────────────────────────────────────────
# discord.com/developers → New App → Bot + Interactions Endpoint
# Handles slash commands via HTTP interactions (not raw messages)
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_PUBLIC_KEY=
DISCORD_DEBRIEF_CHANNEL_ID=

# ── Gmail ────────────────────────────────────────────────────────────────────
# console.cloud.google.com → Enable Gmail API → Create OAuth 2.0 Client ID
# Tokens are stored in n8n credential store — these are for documentation only
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=

# ── Zerodha Kite (READ-ONLY portfolio polling) ───────────────────────────────
# developers.kite.trade → Create app → generate access_token via Kite Connect
# AI is banned from trading — provision read-only scope at broker level too
KITE_API_KEY=
KITE_ACCESS_TOKEN=
KITE_API_BASE_URL=https://api.kite.trade

# ── Generic Broker (Alpaca / other) ──────────────────────────────────────────
# READ-ONLY keys only. Hub guardrails refuse any trade/transfer action.
BROKER_API_BASE_URL=https://paper-api.alpaca.markets
BROKER_API_KEY_ID=
BROKER_API_SECRET_KEY=


# ╔════════════════════════════════════════════════════════════════════════════╗
# ║  END                                                                       ║
# ╚════════════════════════════════════════════════════════════════════════════╝
